# ============================================================
# SAFESTACK Environment Variables (copy to .env and fill in)
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini AI API Keys
VITE_GEMINI_API_KEY=your-gemini-api-key-here
VITE_GEMINI_API_KEY_2=your-second-gemini-api-key-here
VITE_GEMINI_PROJECT_ID=your-project-id

# Stripe (optional - for billing)
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-key-here
